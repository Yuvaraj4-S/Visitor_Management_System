 "message": "<div style=\"font-family: Arial, sans-serif; font-size: 13px; color: #1f2933;\">\n<h3 style=\"margin: 0 0 12px;\">New Hospitality Request</h3>\n<p>A hospitality request has been created and needs review.</p>\n<table style=\"border-collapse: collapse; width: 100%; margin: 12px 0;\">\n<tr style=\"background: #f4f5f7;\"><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Request</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.name }}</td></tr>\n<tr><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Visitor Pass</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.visitor_pass }}</td></tr>\n<tr style=\"background: #f4f5f7;\"><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Visitor</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.visitor_name_display or '-' }}</td></tr>\n<tr><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Visit Window</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.visit_start_time or '-' }} — {{ doc.visit_end_time or '-' }}</td></tr>\n<tr style=\"background: #f4f5f7;\"><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Services</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{% if doc.meal_required %}Meal {% endif %}{% if doc.cab_required %}| Cab {% endif %}{% if doc.hotel_required %}| Hotel {% endif %}{% if doc.buggy_required %}| Buggy {% endif %}{% if doc.factory_tour_required %}| Factory Tour {% endif %}{% if doc.greeting_required %}| Greeting {% endif %}</td></tr>\n</table>\n<p style=\"margin-top: 16px;\"><a href=\"{{ frappe.utils.get_url() }}/app/hospitality-request/{{ doc.name }}\" style=\"background: #2563eb; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px;\">Open Request</a></p>\n</div>",
