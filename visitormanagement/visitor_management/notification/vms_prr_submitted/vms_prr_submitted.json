    "message": "<div style=\"font-family: Arial, sans-serif; font-size: 13px; color: #1f2933;\">\n<h3>New Pre-Registration Request Needs Your Approval</h3>\n<p>A new visitor pre-registration has been submitted and is awaiting approval.</p>\n\n<table style=\"border-collapse: collapse; width: 100%; margin: 12px 0;\">\n<tr style=\"background: #f4f5f7;\"><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Visitor</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.visitor_name }}</td></tr>\n<tr><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Type</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.visitor_type }}</td></tr>\n<tr style=\"background: #f4f5f7;\"><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Company</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.company__organisation or 'N/A' }}</td></tr>\n<tr><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Visit Date</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.visit_date }}</td></tr>\n<tr style=\"background: #f4f5f7;\"><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Time</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.expected_checkin }} - {{ doc.expected_checkout }}</td></tr>\n<tr><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Host</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.person_to_visit }}</td></tr>\n<tr style=\"background: #f4f5f7;\"><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Purpose</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\">{{ doc.purpose_of_visit }}</td></tr>\n<tr><td style=\"padding: 8px; border: 1px solid #ddd;\"><b>Status</b></td><td style=\"padding: 8px; border: 1px solid #ddd;\"><b style=\"color: #fd7e14;\">{{ doc.status }}</b></td></tr>\n</table>\n\n<p style=\"margin-top: 16px;\"><a href=\"{{ frappe.utils.get_url() }}/app/pre-registration-request/{{ doc.name }}\">Review Request</a></p>\n</div>",
    "message_type": "HTML",
    "modified": "2026-04-13 12:00:00.000000",
